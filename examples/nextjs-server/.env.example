# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Public HTTPS URL of the app (ngrok, Vercel, etc.)
# Used for TON Connect manifest and Telegram webhook registration
NEXT_PUBLIC_APP_URL=https://your-ngrok-url.ngrok-free.app

# ── Ribbit credits ────────────────────────────────────────────────────────────
# How many credits equal 1 TON (display conversion only)
CREDITS_PER_TON=100
NEXT_PUBLIC_CREDITS_PER_TON=100

# How many credits 1 Telegram Star buys
CREDITS_PER_STAR=2

# ── TON / x402 payments ───────────────────────────────────────────────────────
# "testnet" or "mainnet"
TON_NETWORK=testnet

# Your TON wallet address — receives on-chain payments
PAYMENT_ADDRESS=your_ton_wallet_address_here

# Jetton master contract (BSA USD on testnet by default)
JETTON_MASTER_ADDRESS=kQCd6G7c_HUBkgwtmGzpdqvHIQoNkYOEE0kSWoc5v57hPPnW

# x402 facilitator URL (leave as-is to use the built-in one)
FACILITATOR_URL=http://localhost:3000/api/facilitator

# Toncenter RPC — get a free API key at https://toncenter.com
TON_RPC_URL=https://testnet.toncenter.com/api/v2/jsonRPC
RPC_API_KEY=your_toncenter_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db
